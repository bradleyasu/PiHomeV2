#:kivy 2.0.0

<Empty>:
    size_hint: None, None

    BoxLayout:
        orientation: 'vertical'
        size: root.size
        pos: root.pos
        spacing: dp(10)
        padding: dp(40), dp(0), dp(40), dp(0)

        Widget:
            size_hint_y: 1

        Label:
            text: root.icon
            font_size: '64sp'
            font_name: 'ArialUnicode'
            size_hint_y: None
            height: dp(80)
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            opacity: 0.5

        Label:
            text: root.message
            font_size: '18sp'
            font_name: 'Nunito'
            bold: True
            color: root.text_color
            halign: 'center'
            valign: 'middle'
            text_size: self.width, None
            size_hint_y: None
            height: dp(30)

        Label:
            text: root.subtitle
            font_size: '13sp'
            font_name: 'Nunito'
            color: root.text_color[0], root.text_color[1], root.text_color[2], 0.5
            halign: 'center'
            valign: 'middle'
            text_size: self.width, None
            size_hint_y: None
            height: dp(22)
            opacity: 1 if root.subtitle else 0

        Widget:
            size_hint_y: 1