#:kivy 2.0.0

<PiHomeSwitch>:
    size: root.size
    pos: root.pos
    size_hint: None, None

    canvas:
        # Track
        Color:
            rgba: root.track_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.height / 2]

        # Thumb shadow
        Color:
            rgba: 0, 0, 0, 0.18
        Ellipse:
            pos: self.x + root.offset + dp(1), self.y + dp(2)
            size: self.height - dp(6), self.height - dp(6)

        # Thumb
        Color:
            rgba: root.thumb_color
        Ellipse:
            pos: self.x + root.offset, self.y + dp(3)
            size: self.height - dp(6), self.height - dp(6)
