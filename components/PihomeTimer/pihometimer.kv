#:kivy 2.0.0
<PiHomeTimer>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(54)
    padding: dp(14), dp(9), dp(8), dp(9)
    spacing: dp(10)

    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size

    # ── Arc progress ring ──────────────────────────────────────────────────────
    Widget:
        size_hint: None, None
        size: dp(36), dp(36)
        pos_hint: {'center_y': 0.5}
        canvas:
            # track ring
            Color:
                rgba: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.22
            Line:
                circle: self.center_x, self.center_y, dp(14)
                width: dp(2)
            # progress arc (CCW from 12 o'clock)
            Color:
                rgba: root.accent_color
            Line:
                circle: self.center_x, self.center_y, dp(14), 90, 90 + 360 * root.progress
                width: dp(2.5)

    # ── Label + countdown ──────────────────────────────────────────────────────
    BoxLayout:
        orientation: 'vertical'
        spacing: dp(1)
        Label:
            text: root.label
            color: root.text_color
            font_size: '12sp'
            font_name: 'Nunito'
            bold: True
            halign: 'left'
            valign: 'bottom'
            text_size: self.width, None
        Label:
            text: root.time_label
            color: root.accent_color
            font_size: '19sp'
            font_name: 'Nunito'
            halign: 'left'
            valign: 'top'
            text_size: self.width, None

    # ── Cancel button ──────────────────────────────────────────────────────────
    Button:
        size_hint: None, None
        size: dp(34), dp(34)
        pos_hint: {'center_y': 0.5}
        text: '\ue5cd'
        font_name: 'MaterialIcons'
        color: root.muted_color
        font_size: '17sp'
        background_normal: ''
        background_color: 0, 0, 0, 0
        on_release: root._do_cancel()
        canvas.before:
            Color:
                rgba: 1, 1, 1, 0.08
            Ellipse:
                pos: self.x + dp(2), self.y + dp(2)
                size: self.width - dp(4), self.height - dp(4)