#:kivy 2.0.0
<PiHomeTimer>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(54)
    padding: dp(14), dp(9), dp(8), dp(9)
    spacing: dp(10)
    # No KV canvas blocks — all drawing done in Python to avoid Pi GL corruption.

    Widget:
        id: arc_widget
        size_hint: None, None
        size: dp(36), dp(36)

    BoxLayout:
        orientation: 'vertical'
        spacing: dp(1)

        Label:
            text: root.label
            color: root.text_color
            font_size: '12sp'
            font_name: 'Nunito'
            halign: 'left'
            valign: 'middle'
            text_size: self.width, None

        Label:
            text: root.time_label
            color: root.accent_color
            font_size: '13sp'
            font_name: 'Nunito'
            halign: 'left'
            valign: 'middle'
            text_size: self.width, None

    Label:
        id: cancel_lbl
        size_hint: None, None
        size: dp(34), dp(34)
        text: '\ue5cd'
        font_name: 'MaterialIcons'
        color: root.muted_color
        font_size: '17sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size