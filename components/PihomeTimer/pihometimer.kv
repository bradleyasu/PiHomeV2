#:kivy 2.0.0
<PiHomeTimer>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(54)
    padding: dp(14), dp(9), dp(8), dp(9)
    spacing: dp(10)
    # DIAGNOSTIC: zero canvas instructions, zero child canvas blocks.
    # Three plain Labels only — same as what we know works.
    # If this resolves the black screen the root canvas: block is the culprit.

    Label:
        size_hint: None, None
        width: dp(36)
        height: dp(36)
        text: ''

    Label:
        text: root.label + '  ' + root.time_label
        color: root.text_color
        font_size: '14sp'
        font_name: 'Nunito'
        halign: 'left'
        valign: 'middle'
        text_size: self.width, None

    Label:
        id: cancel_lbl
        size_hint: None, None
        size: dp(34), dp(34)
        text: '\ue5cd'
        font_name: 'MaterialIcons'
        color: root.muted_color
        font_size: '17sp'
        halign: 'center'
        valign: 'middle'
        text_size: self.size