#:kivy 2.0.0
<Hamburger>:
    size_hint: None, None
    size: dp(40), dp(44)
    canvas:
        # ── Top bar — rotates +45° and slides to centre to form top arm of ✕
        PushMatrix
        Rotate:
            angle: root.top_angle
            origin: (self.x + dp(20), self.y + dp(36.5) + root.top_y_offset, 0)
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.x + dp(6), self.y + dp(35) + root.top_y_offset
            size: dp(28), dp(3)
            radius: [dp(1.5)]
        PopMatrix

        # ── Middle bar — fades out when open
        Color:
            rgba: 1, 1, 1, root.mid_opacity
        RoundedRectangle:
            pos: self.x + dp(6), self.y + dp(24)
            size: dp(28), dp(3)
            radius: [dp(1.5)]

        # ── Bottom bar — rotates -45° and slides to centre to form bottom arm of ✕
        PushMatrix
        Rotate:
            angle: root.bottom_angle
            origin: (self.x + dp(20), self.y + dp(14.5) + root.bottom_y_offset, 0)
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.x + dp(6), self.y + dp(13) + root.bottom_y_offset
            size: dp(28), dp(3)
            radius: [dp(1.5)]
        PopMatrix
