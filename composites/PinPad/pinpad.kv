#:kivy 2.0.0
<PinPad>:
    canvas.before:
        # Scrim
        Color:
            rgba: self.background_color
        Rectangle:
            pos: self.pos
            size: self.size

    canvas:
        # Card shadow
        Color:
            rgba: 0, 0, 0, 0.5
        BoxShadow:
            pos: self.width / 2 - dp(160), self.y_position
            size: dp(320), dp(405)
            offset: 0, -12
            spread_radius: -16, -16
            border_radius: 24, 24, 24, 24
            blur_radius: 60
        # Card surface
        Color:
            rgba: self.pinpad_background_color
        RoundedRectangle:
            size: dp(320), dp(405)
            pos: self.width / 2 - dp(160), self.y_position
            radius: [dp(24)]

    canvas.after:
        # Empty dot rings — anchored to y_position so they animate with the card
        # _dot_x_offset shifts dots horizontally during shake animation
        Color:
            rgba: root.dot_empty_color
        Line:
            width: dp(1.5)
            circle: root.width/2 - dp(45) + root._dot_x_offset, root.y_position + dp(330), dp(8), 0, 360
        Line:
            width: dp(1.5)
            circle: root.width/2 - dp(15) + root._dot_x_offset, root.y_position + dp(330), dp(8), 0, 360
        Line:
            width: dp(1.5)
            circle: root.width/2 + dp(15) + root._dot_x_offset, root.y_position + dp(330), dp(8), 0, 360
        Line:
            width: dp(1.5)
            circle: root.width/2 + dp(45) + root._dot_x_offset, root.y_position + dp(330), dp(8), 0, 360
        # Filled dots (angle_end drives 0=empty, 360=full)
        Color:
            rgba: root.dot_filled_color
        Ellipse:
            angle_start: 0
            angle_end: self.pin_one
            size: dp(16), dp(16)
            pos: root.width/2 - dp(53) + root._dot_x_offset, root.y_position + dp(322)
        Ellipse:
            angle_start: 0
            angle_end: self.pin_two
            size: dp(16), dp(16)
            pos: root.width/2 - dp(23) + root._dot_x_offset, root.y_position + dp(322)
        Ellipse:
            angle_start: 0
            angle_end: self.pin_three
            size: dp(16), dp(16)
            pos: root.width/2 + dp(7) + root._dot_x_offset, root.y_position + dp(322)
        Ellipse:
            angle_start: 0
            angle_end: self.pin_four
            size: dp(16), dp(16)
            pos: root.width/2 + dp(37) + root._dot_x_offset, root.y_position + dp(322)

    FloatLayout:
        id: pin_pad_float_container
        pos: 0, 0
        size_hint: None, None
        size: root.size

        Label:
            text: 'PIN REQUIRED'
            size: dp(300), dp(24)
            pos: root.width/2 - dp(150), root.y_position + dp(368)
            font_size: '13sp'
            bold: True
            size_hint: None, None
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            color: root.pinpad_button_color
            font_name: 'Nunito'

        GridLayout:
            id: pin_pad_layout
            cols: 3
            rows: 4
            spacing: dp(24)
            size_hint: None, None
            size: dp(198), dp(272)
            pos: root.width / 2 - dp(99), root.y_position + dp(20)
            opacity: root.pinpad_opacity
