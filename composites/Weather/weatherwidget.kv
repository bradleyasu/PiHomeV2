#:kivy 2.0.0
<WeatherWidget>:
    size_hint: None, None
    size: self.size

    # ── Alert carousel (centered on screen, behind overlay) ─────────────────
    # Collapses to 0x0 when no alerts so it cannot intercept touches
    FloatLayout:
        size_hint: None, None
        size: (root.parent.size if root.parent else (800, 480)) if root.alert_count > 0 else (0, 0)
        pos: (root.parent.pos if root.parent else (0, 0)) if root.alert_count > 0 else (0, 0)
        opacity: root.alert_opacity

        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            size: min(root.parent.width - dp(80), dp(500)) if root.parent else dp(400), dp(200)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}
            spacing: dp(6)

            Carousel:
                id: alert_carousel
                direction: 'right'
                size_hint_y: None
                height: dp(170)
                min_move: 0.1
                anim_move_duration: 0.3

            # Page indicator dots
            BoxLayout:
                id: alert_dots
                orientation: 'horizontal'
                size_hint: None, None
                height: dp(14)
                width: self.minimum_width
                pos_hint: {'center_x': 0.5}
                spacing: dp(6)
                padding: dp(4), 0

    # ── Expanded overlay (shown on tap) ──────────────────────────────────────
    FloatLayout:
        id: overlay_card
        size_hint: None, None
        size: root.overlay_size
        pos: dp(20), dp(20 + root.overlay_y_offset)
        opacity: root.overlay_opacity

        # Solid card — respects light/dark mode via root.card_color
        canvas.before:
            Color:
                rgba: root.card_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(24)]
            Color:
                rgba: root.card_border_color
            Line:
                rounded_rectangle: [self.pos[0] + dp(1), self.pos[1] + dp(1), self.size[0] - dp(2), self.size[1] - dp(2), dp(24)]
                width: 1.2

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            padding: dp(20), dp(14)
            spacing: dp(10)

            # ── Hero: icon + temp + feels like ───────────────────────────────
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(96)
                spacing: dp(14)

                NetworkImage:
                    url: root.icon_large
                    fallback_url: root.icon_fallback_large
                    size_hint: None, None
                    size: dp(92), dp(92)
                    enable_stretch: True

                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(2)

                    # text_size width-only → never clips vertically
                    Label:
                        text: root.temp + '\u00B0F'
                        color: root.text_color
                        font_size: '40sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(56)

                    Label:
                        text: 'Feels like ' + root.feelsLike + '\u00B0F'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.55
                        font_size: '13sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(20)

                # Hourly / Daily toggle — vertically centered in hero
                AnchorLayout:
                    size_hint_x: None
                    width: dp(96)
                    anchor_x: 'right'
                    anchor_y: 'center'

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint: None, None
                        size: dp(96), dp(28)
                        spacing: 0

                        canvas.before:
                            Color:
                                rgba: root.chip_bg_color
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(14)]

                        # Hourly segment
                        BoxLayout:
                            size_hint_x: None
                            width: dp(48)
                            on_touch_down: if self.collide_point(*args[1].pos): root.show_hourly = True
                            canvas.before:
                                Color:
                                    rgba: (root.text_color[0], root.text_color[1], root.text_color[2], 0.18) if root.show_hourly else (0, 0, 0, 0)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(14), dp(0), dp(0), dp(14)]
                            Label:
                                text: 'Hourly'
                                font_size: '10sp'
                                font_name: 'Nunito'
                                bold: root.show_hourly
                                color: root.text_color if root.show_hourly else (root.text_color[0], root.text_color[1], root.text_color[2], 0.4)
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                        # Daily segment
                        BoxLayout:
                            size_hint_x: None
                            width: dp(48)
                            on_touch_down: if self.collide_point(*args[1].pos): root.show_hourly = False
                            canvas.before:
                                Color:
                                    rgba: (root.text_color[0], root.text_color[1], root.text_color[2], 0.18) if not root.show_hourly else (0, 0, 0, 0)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(0), dp(14), dp(14), dp(0)]
                            Label:
                                text: 'Daily'
                                font_size: '10sp'
                                font_name: 'Nunito'
                                bold: not root.show_hourly
                                color: root.text_color if not root.show_hourly else (root.text_color[0], root.text_color[1], root.text_color[2], 0.4)
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

            # Divider
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: root.divider_color
                    Line:
                        points: [self.x, self.y, self.right, self.y]
                        width: 1

            # ── Stat chips: 3 cols × 2 rows ──────────────────────────────────
            GridLayout:
                cols: 3
                spacing: dp(6)
                size_hint_y: None
                height: dp(110)

                UVChip:
                    id: chip_uv
                    chip_bg_color: root.chip_bg_color
                    text_color: root.text_color

                WindChip:
                    id: chip_wind
                    chip_bg_color: root.chip_bg_color
                    text_color: root.text_color

                PrecipChip:
                    id: chip_precip
                    chip_bg_color: root.chip_bg_color
                    text_color: root.text_color

                HumidityChip:
                    id: chip_humidity
                    chip_bg_color: root.chip_bg_color
                    text_color: root.text_color

                CloudChip:
                    id: chip_cloud
                    chip_bg_color: root.chip_bg_color
                    text_color: root.text_color

                SunMoonChip:
                    id: chip_sunmoon
                    chip_bg_color: root.chip_bg_color
                    text_color: root.text_color

            # Divider
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: root.divider_color
                    Line:
                        points: [self.x, self.y, self.right, self.y]
                        width: 1

            # ── Hourly / Daily forecast (scrollable) ───────────────────────
            RelativeLayout:
                size_hint_y: None
                height: dp(121)

                ScrollView:
                    id: hourly_scroll
                    size_hint: (1, 1) if root.show_hourly else (0, 0)
                    opacity: 1 if root.show_hourly else 0
                    do_scroll_x: True
                    do_scroll_y: False
                    bar_width: dp(0)
                    scroll_type: ['content']

                    BoxLayout:
                        id: hourly_container
                        orientation: 'horizontal'
                        size_hint_x: None
                        width: self.minimum_width
                        height: dp(121)
                        spacing: dp(6)
                        padding: dp(2), 0

                ScrollView:
                    id: daily_scroll
                    size_hint: (0, 0) if root.show_hourly else (1, 1)
                    opacity: 0 if root.show_hourly else 1
                    do_scroll_x: True
                    do_scroll_y: False
                    bar_width: dp(0)
                    scroll_type: ['content']

                    BoxLayout:
                        id: daily_container
                        orientation: 'horizontal'
                        size_hint_x: None
                        width: self.minimum_width
                        height: dp(121)
                        spacing: dp(6)
                        padding: dp(2), 0

            # Spacer — absorbs leftover vertical space so content stays at the top
            Widget:

    # ── Compact pill (always visible) ────────────────────────────────────────
    BoxLayout:
        orientation: 'horizontal'
        size_hint: None, None
        size: dp(178), dp(44)
        pos: root.right - dp(178), root.y + dp(root.y_offset)
        padding: dp(6), dp(4)
        spacing: dp(6)

        canvas.before:
            Color:
                rgba: root.pill_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(22)]
            Color:
                rgba: root.pill_border_color
            Line:
                rounded_rectangle: [self.pos[0] + dp(1), self.pos[1] + dp(1), self.size[0] - dp(2), self.size[1] - dp(2), dp(22)]
                width: 1

        # Weather icon
        NetworkImage:
            url: root.icon
            fallback_url: root.icon_fallback
            size_hint: None, None
            size: dp(36), dp(36)
            enable_stretch: True

        # Current temperature
        Label:
            text: root.temp + '\u00B0'
            color: root.text_color
            font_size: '20sp'
            font_name: 'Nunito'
            bold: True
            halign: 'left'
            valign: 'middle'
            text_size: self.width, None
            size_hint_x: None
            width: dp(38)

        # Vertical divider
        Widget:
            size_hint: None, None
            size: dp(1), dp(26)
            pos_hint: {'center_y': 0.5}
            canvas:
                Color:
                    rgba: root.pill_divider_color
                Line:
                    points: [self.center_x, self.y, self.center_x, self.top]
                    width: 1

        # Secondary stat: UV index (if > 5) or precip chance
        Label:
            text: root.pill_icon
            color: root.pill_stat_color
            font_name: 'MaterialIcons'
            size_hint: None, 1
            width: dp(20)
            font_size: '22sp'
            halign: 'center'
            valign: 'middle'
            text_size: self.size

        Label:
            text: ' ' + root.pill_stat
            color: root.pill_stat_color
            font_size: '13sp'
            font_name: 'Nunito'
            bold: True
            halign: 'left'
            valign: 'middle'
            text_size: self.width, None
            width: self.texture_size[0] + dp(6)
