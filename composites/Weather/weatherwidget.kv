#:kivy 2.0.0
<WeatherWidget>:
    size_hint: None, None
    size: self.size

    # ── Expanded overlay (shown on tap) ──────────────────────────────────────
    FloatLayout:
        size_hint: None, None
        size: root.overlay_size
        pos: dp(20), dp(20 + root.overlay_y_offset)
        opacity: root.overlay_opacity

        # Solid card — respects light/dark mode via root.card_color
        canvas.before:
            Color:
                rgba: root.card_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(24)]
            Color:
                rgba: root.card_border_color
            Line:
                rounded_rectangle: [self.pos[0] + dp(1), self.pos[1] + dp(1), self.size[0] - dp(2), self.size[1] - dp(2), dp(24)]
                width: 1.2

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 1
            pos_hint: {'x': 0, 'y': 0}
            padding: dp(20), dp(14)
            spacing: dp(10)

            # ── Hero: icon + temp + feels like ───────────────────────────────
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(96)
                spacing: dp(14)

                NetworkImage:
                    url: root.icon
                    fallback_url: root.icon_fallback
                    size_hint: None, None
                    size: dp(92), dp(92)
                    enable_stretch: True

                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(2)

                    # text_size width-only → never clips vertically
                    Label:
                        text: root.temp + '\u00B0F'
                        color: root.text_color
                        font_size: '40sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(56)

                    Label:
                        text: 'Feels like ' + root.feelsLike + '\u00B0F'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.55
                        font_size: '13sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(20)

                # Hourly / Daily toggle — vertically centered in hero
                AnchorLayout:
                    size_hint_x: None
                    width: dp(96)
                    anchor_x: 'right'
                    anchor_y: 'center'

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint: None, None
                        size: dp(96), dp(28)
                        spacing: 0

                        canvas.before:
                            Color:
                                rgba: root.chip_bg_color
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(14)]

                        # Hourly segment
                        BoxLayout:
                            size_hint_x: None
                            width: dp(48)
                            on_touch_down: if self.collide_point(*args[1].pos): root.show_hourly = True
                            canvas.before:
                                Color:
                                    rgba: (root.text_color[0], root.text_color[1], root.text_color[2], 0.18) if root.show_hourly else (0, 0, 0, 0)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(14), dp(0), dp(0), dp(14)]
                            Label:
                                text: 'Hourly'
                                font_size: '10sp'
                                font_name: 'Nunito'
                                bold: root.show_hourly
                                color: root.text_color if root.show_hourly else (root.text_color[0], root.text_color[1], root.text_color[2], 0.4)
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

                        # Daily segment
                        BoxLayout:
                            size_hint_x: None
                            width: dp(48)
                            on_touch_down: if self.collide_point(*args[1].pos): root.show_hourly = False
                            canvas.before:
                                Color:
                                    rgba: (root.text_color[0], root.text_color[1], root.text_color[2], 0.18) if not root.show_hourly else (0, 0, 0, 0)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [dp(0), dp(14), dp(14), dp(0)]
                            Label:
                                text: 'Daily'
                                font_size: '10sp'
                                font_name: 'Nunito'
                                bold: not root.show_hourly
                                color: root.text_color if not root.show_hourly else (root.text_color[0], root.text_color[1], root.text_color[2], 0.4)
                                halign: 'center'
                                valign: 'middle'
                                text_size: self.size

            # Divider
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: root.divider_color
                    Line:
                        points: [self.x, self.y, self.right, self.y]
                        width: 1

            # ── Stat chips: 3 cols × 2 rows ──────────────────────────────────
            GridLayout:
                cols: 3
                spacing: dp(6)
                size_hint_y: None
                height: dp(96)

                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10), dp(8), dp(10), dp(8)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.chip_bg_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    Label:
                        text: 'UV Index'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.50
                        font_size: '11sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)
                    Label:
                        text: root.uvIndex
                        color: root.text_color
                        font_size: '14sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)

                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10), dp(8), dp(10), dp(8)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.chip_bg_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    Label:
                        text: 'Wind'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.50
                        font_size: '11sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)
                    Label:
                        text: root.windSpeed
                        color: root.text_color
                        font_size: '14sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)

                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10), dp(8), dp(10), dp(8)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.chip_bg_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    Label:
                        text: 'Precip'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.50
                        font_size: '11sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)
                    Label:
                        text: root.precipPercent
                        color: root.text_color
                        font_size: '14sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)

                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10), dp(8), dp(10), dp(8)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.chip_bg_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    Label:
                        text: 'Humidity'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.50
                        font_size: '11sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)
                    Label:
                        text: root.humidity
                        color: root.text_color
                        font_size: '14sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)

                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10), dp(8), dp(10), dp(8)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.chip_bg_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    Label:
                        text: 'Cloud Cover'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.50
                        font_size: '11sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)
                    Label:
                        text: root.cloudCover
                        color: root.text_color
                        font_size: '14sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)

                BoxLayout:
                    orientation: 'vertical'
                    padding: dp(10), dp(8), dp(10), dp(8)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.chip_bg_color
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]
                    Label:
                        text: 'Air Quality'
                        color: root.text_color[0], root.text_color[1], root.text_color[2], 0.50
                        font_size: '11sp'
                        font_name: 'Nunito'
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)
                    Label:
                        text: root.airQuality
                        color: root.text_color
                        font_size: '14sp'
                        font_name: 'Nunito'
                        bold: True
                        halign: 'left'
                        valign: 'middle'
                        text_size: self.width, None
                        size_hint_y: None
                        height: dp(14)

            # Divider
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: root.divider_color
                    Line:
                        points: [self.x, self.y, self.right, self.y]
                        width: 1

            # ── Hourly / Daily forecast (shared fixed-height slot) ───────────
            RelativeLayout:
                size_hint_y: None
                height: dp(145)

                AnchorLayout:
                    opacity: 1 if root.show_hourly else 0
                    size_hint: 1, 1
                    anchor_x: 'center'
                    anchor_y: 'center'
                    GridLayout:
                        cols: 6
                        spacing: dp(6)
                        size_hint: None, None
                        size: dp(100) * 6 + dp(6) * 5, dp(145)
                        WeatherDetails:
                            details: root.future[0] if len(root.future) > 0 else {}
                        WeatherDetails:
                            details: root.future[1] if len(root.future) > 1 else {}
                        WeatherDetails:
                            details: root.future[2] if len(root.future) > 2 else {}
                        WeatherDetails:
                            details: root.future[3] if len(root.future) > 3 else {}
                        WeatherDetails:
                            details: root.future[4] if len(root.future) > 4 else {}
                        WeatherDetails:
                            details: root.future[5] if len(root.future) > 5 else {}

                AnchorLayout:
                    opacity: 1 if not root.show_hourly else 0
                    size_hint: 1, 1
                    anchor_x: 'center'
                    anchor_y: 'center'
                    GridLayout:
                        cols: 6
                        spacing: dp(6)
                        size_hint: None, None
                        size: dp(100) * 6 + dp(6) * 5, dp(145)
                        WeatherDetails:
                            is_daily: True
                            details: root.future_daily[0] if len(root.future_daily) > 0 else {}
                        WeatherDetails:
                            is_daily: True
                            details: root.future_daily[1] if len(root.future_daily) > 1 else {}
                        WeatherDetails:
                            is_daily: True
                            details: root.future_daily[2] if len(root.future_daily) > 2 else {}
                        WeatherDetails:
                            is_daily: True
                            details: root.future_daily[3] if len(root.future_daily) > 3 else {}
                        WeatherDetails:
                            is_daily: True
                            details: root.future_daily[4] if len(root.future_daily) > 4 else {}
                        WeatherDetails:
                            is_daily: True
                            details: root.future_daily[5] if len(root.future_daily) > 5 else {}

            # Spacer — absorbs leftover vertical space so content stays at the top
            Widget:

    # ── Compact pill (always visible) ────────────────────────────────────────
    BoxLayout:
        orientation: 'horizontal'
        size_hint: None, None
        size: dp(178), dp(44)
        pos: root.right - dp(178), root.y + dp(root.y_offset)
        padding: dp(6), dp(4)
        spacing: dp(6)

        canvas.before:
            Color:
                rgba: root.pill_bg_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(22)]
            Color:
                rgba: root.pill_border_color
            Line:
                rounded_rectangle: [self.pos[0] + dp(1), self.pos[1] + dp(1), self.size[0] - dp(2), self.size[1] - dp(2), dp(22)]
                width: 1

        # Weather icon
        NetworkImage:
            url: root.icon
            fallback_url: root.icon_fallback
            size_hint: None, None
            size: dp(36), dp(36)
            enable_stretch: True

        # Current temperature
        Label:
            text: root.temp + '\u00B0'
            color: root.text_color
            font_size: '20sp'
            font_name: 'Nunito'
            bold: True
            halign: 'left'
            valign: 'middle'
            text_size: self.width, None
            size_hint_x: None
            width: dp(38)

        # Vertical divider
        Widget:
            size_hint: None, None
            size: dp(1), dp(26)
            pos_hint: {'center_y': 0.5}
            canvas:
                Color:
                    rgba: root.pill_divider_color
                Line:
                    points: [self.center_x, self.y, self.center_x, self.top]
                    width: 1

        # Secondary stat: UV index (if > 5) or precip chance
        Label:
            text: ' ' + root.pill_stat
            color: root.pill_stat_color
            font_size: '13sp'
            font_name: 'Nunito'
            bold: True
            halign: 'left'
            valign: 'middle'
            text_size: self.width, None
            width: self.texture_size[0] + dp(6)
