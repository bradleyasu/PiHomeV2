#:kivy 2.0.0
<WeatherDetails>:
    size_hint: None, None
    size: dp(100), dp(121)

    canvas.before:
        Color:
            rgba: root.card_bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(14)]
        Color:
            rgba: root.card_border_color
        Line:
            rounded_rectangle: [self.pos[0] + dp(1), self.pos[1] + dp(1), self.size[0] - dp(2), self.size[1] - dp(2), dp(14)]
            width: 1

    BoxLayout:
        orientation: 'vertical'
        size: root.size
        pos: root.pos
        padding: dp(6), dp(8)
        spacing: dp(2)

        Label:
            text: root.day
            color: root.text_color[0], root.text_color[1], root.text_color[2], 0.5
            font_size: '11sp'
            font_name: 'Nunito'
            halign: 'center'
            valign: 'middle'
            text_size: self.width, None
            size_hint_y: None
            height: dp(16)

        # Icon fills whatever space is left after the fixed-height labels
        NetworkImage:
            url: root.icon
            fallback_url: root.icon_fallback
            size_hint: None, 1
            width: root.width - dp(12)
            pos_hint: {'center_x': 0.5}
            enable_stretch: True

        Label:
            text: root.temp
            color: root.text_color
            font_size: '15sp'
            font_name: 'Nunito'
            halign: 'center'
            valign: 'middle'
            text_size: self.width, None
            size_hint_y: None
            height: dp(22)

        Label:
            text: root.precip
            color: root.text_color[0], root.text_color[1], root.text_color[2], 0.5
            font_size: '11sp'
            font_name: 'Nunito'
            halign: 'center'
            valign: 'middle'
            text_size: self.width, None
            size_hint_y: None
            height: dp(18)
