#:kivy 2.0.0
<AppIcon>:
    orientation: 'vertical'
    size_hint: None, None
    padding: dp(8), dp(10), dp(8), dp(8)
    spacing: dp(6)

    canvas.before:
        PushMatrix
        Translate:
            y: root.translate_y
        # Glassy card surface
        Color:
            rgba: 1, 1, 1, 0.09
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(18)]
        # Subtle border
        Color:
            rgba: 1, 1, 1, 0.12
        Line:
            rounded_rectangle: [self.pos[0] + dp(0.5), self.pos[1] + dp(0.5), self.size[0] - dp(1), self.size[1] - dp(1), dp(18)]
            width: 0.8

    canvas.after:
        PopMatrix

    NetworkImage:
        url: root.icon
        size_hint: 1, 1
        enable_stretch: True

    Label:
        text: root.label
        color: 1, 1, 1, 0.88
        font_size: '11sp'
        font_name: 'Nunito'
        bold: True
        halign: 'center'
        valign: 'middle'
        text_size: self.width, None
        shorten: True
        shorten_from: 'right'
        size_hint_y: None
        height: dp(16)
