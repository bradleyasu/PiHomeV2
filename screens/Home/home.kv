#:kivy 2.0.0
<HomeScreen>:
    canvas.before:
        Color:
            rgba: self.background
        Rectangle:
            pos: self.pos
            size: self.size

    FloatLayout:
        size_hint: 1, 1
        pos: root.pos
        size: root.size

        # ── Startup logo — centered, fades out ────────────────────────────────
        Label:
            id: home_pihome_logo
            color: root.text_color
            text: "PiHome"
            pos_hint: {'center_x': .5, 'center_y': .5}
            font_size: '72sp'
            font_name: 'Nunito'
            bold: True
            opacity: root.logo_opacity

        # ── Date / Time — lower-left, slides up on startup ────────────────────
        Label:
            id: home_date
            color: root.text_color[0], root.text_color[1], root.text_color[2], 0.6
            text: root.date
            font_size: '18sp'
            font_name: 'Nunito'
            size_hint: None, None
            size: self.texture_size
            pos: dp(16), dp(122) + root.date_time_y_offset
            opacity: root.date_time_opacity

        Label:
            id: home_time
            color: root.text_color
            text: root.time
            font_size: '80sp'
            font_name: 'Nunito'
            bold: True
            size_hint: None, None
            size: self.texture_size
            pos: dp(16), dp(16) + root.date_time_y_offset
            opacity: root.date_time_opacity

        # ── Reddit news card — lower-right corner ─────────────────────────
        RedditWidget:
            id: reddit_widget
            size_hint: None, None
            pos: root.width - dp(326), dp(16)

        # ── Weather pill — top-right, hidden until splash finishes ────────────
        WeatherWidget:
            id: weather_widget
            size_hint: None, None
            size: root.width - dp(16), dp(52)
            pos: 0, root.height - dp(52)
            opacity: root.weather_opacity

