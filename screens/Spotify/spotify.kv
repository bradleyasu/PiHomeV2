#:kivy 2.0.0

<SpotifyScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            size: self.size
            pos: self.pos
        # Subtle top-center accent blob
        Color:
            rgba: 0.11, 0.73, 0.33, 0.03
        Ellipse:
            pos: self.center_x - self.width * 0.7, self.height * 0.45
            size: self.width * 1.4, self.height * 0.9

    BoxLayout:
        id: content_area
        orientation: "vertical"
        size_hint: 1, 1
        pos_hint: {"center_x": 0.5, "center_y": 0.5}
