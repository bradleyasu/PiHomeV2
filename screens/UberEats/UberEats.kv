#:kivy 2.0.0

# ─────────────────────────────────────────────────────────────────────────────
# Uber Eats screen
# The header is declared here in KV.  The content area below it is built and
# rebuilt entirely in Python (UberEats.py) depending on whether an order is
# active.  MapView, progress bar, and hero image are all constructed there.
# ─────────────────────────────────────────────────────────────────────────────

<UberEatsScreen>:

    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos:  self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        # ── Header ────────────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(64)
            padding: [dp(68), dp(10), dp(16), dp(10)]
            spacing: dp(10)

            canvas.before:
                Color:
                    rgba: root.header_color
                Rectangle:
                    pos:  self.pos
                    size: self.size
                # Bottom hairline divider
                Color:
                    rgba: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.12
                Rectangle:
                    pos:  self.x, self.y
                    size: self.width, dp(1)

            # Restaurant name / "Uber Eats" when idle
            Label:
                text: root.restaurant_name
                font_name: 'Nunito'
                font_size: '18sp'
                bold: True
                color: root.text_color
                halign: 'left'
                valign: 'middle'
                text_size: self.size
                size_hint_x: 1

            # ETA badge — fades out when no active order
            BoxLayout:
                size_hint: None, None
                size: dp(104), dp(34)
                pos_hint: {'center_y': 0.5}
                opacity: 1 if root.eta_text else 0
                padding: [dp(10), 0, dp(10), 0]

                canvas.before:
                    Color:
                        rgba: root.brand_color[0], root.brand_color[1], root.brand_color[2], 0.18
                    RoundedRectangle:
                        pos:    self.pos
                        size:   self.size
                        radius: [dp(17)]

                Label:
                    text: root.eta_text
                    font_name: 'Nunito'
                    font_size: '12sp'
                    bold: True
                    color: root.brand_color
                    halign: 'center'
                    valign: 'middle'
                    text_size: self.size

        # ── Dynamic content area ──────────────────────────────────────────────
        # Cleared and rebuilt by _rebuild_content() in Python whenever
        # order_active changes.  Shows either the empty-state panel or
        # the active-order panel (hero image + status card + map).
        BoxLayout:
            id: content_area
            orientation: 'vertical'
            size_hint: 1, 1

