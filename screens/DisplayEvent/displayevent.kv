#:kivy 2.0.0
#:import dp kivy.metrics.dp

<DisplayEvent>:

    # ── Solid color background (fallback / tint when no image) ────────────────
    canvas.before:
        Color:
            rgba: root.background
        Rectangle:
            pos: self.pos
            size: self.size

    # ── Inset background image with rounded corners ───────────────────────────
    # Sits inside a padded area so the solid background color shows as a border.
    AsyncImage:
        source: root.image
        allow_stretch: True
        keep_ratio: True
        size_hint: None, None
        size: root.width - dp(32), root.height - dp(32)
        pos: root.x + dp(16), root.y + dp(16)
        opacity: 1 if root.image else 0
        canvas.before:
            StencilPush
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(16)]
            StencilUse
        canvas.after:
            StencilUnUse
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(16)]
            StencilPop

    # ── Dark scrim over the background image (softens contrast) ───────────────
    Widget:
        size_hint: None, None
        size: root.width - dp(32), root.height - dp(32)
        pos: root.x + dp(16), root.y + dp(16)
        opacity: 0.45 if root.image else 0
        canvas:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size

    # ── Content layer ─────────────────────────────────────────────────────────
    FloatLayout:
        size: root.size
        pos: root.pos

        # Centered content card — dark semi-transparent surface keeps text
        # legible regardless of what the background image contains.
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(14)
            padding: dp(28), dp(28), dp(28), dp(28)
            size_hint: None, None
            width: min(root.width - dp(64), dp(520))
            height: root.height - dp(100)
            pos_hint: {'center_x': 0.5, 'center_y': 0.5}

            canvas.before:
                Color:
                    rgba: 0, 0, 0, 0.62
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(18)]

            # ── Title ─────────────────────────────────────────────────────────
            Label:
                text: root.title
                font_name: 'Nunito'
                bold: True
                font_size: '26sp'
                color: 1, 1, 1, 1
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                halign: 'center'
                valign: 'top'

            # ── Divider ───────────────────────────────────────────────────────
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.15
                    Rectangle:
                        pos: self.x + dp(16), self.y
                        size: self.width - dp(32), dp(1)

            # ── Scrollable message ────────────────────────────────────────────
            ScrollView:
                id: scroll_area
                size_hint_y: 1
                do_scroll_x: False
                bar_color: 1, 1, 1, 0.25
                bar_inactive_color: 1, 1, 1, 0.08
                bar_width: dp(3)

                Label:
                    text: root.message
                    font_name: 'Nunito'
                    font_size: '15sp'
                    color: 1, 1, 1, 0.88
                    size_hint_y: None
                    height: max(self.texture_size[1], scroll_area.height)
                    text_size: self.width, None
                    halign: 'center'
                    valign: 'top'

        # ── "Tap to dismiss" hint at the bottom ───────────────────────────────
        Label:
            text: 'Tap anywhere to dismiss'
            font_name: 'Nunito'
            font_size: '11sp'
            color: 1, 1, 1, 0.28
            size_hint: None, None
            size: root.width, dp(28)
            pos: root.x, root.y + dp(14)
            halign: 'center'
            text_size: self.size

        # ── Countdown ring (bottom-right, hidden when no timeout) ─────────────
        Widget:
            id: countdown_ring
            opacity: 1 if root.timeout_seconds > 0 else 0
            size_hint: None, None
            size: dp(60), dp(60)
            pos: root.right - dp(76), root.y + dp(10)

            canvas.before:
                # Track ring
                Color:
                    rgba: 1, 1, 1, 0.12
                Line:
                    circle: self.center_x, self.center_y, dp(22), 0, 360
                    width: dp(2.5)
                # Depleting arc — starts full at top, shrinks counter-clockwise
                Color:
                    rgba: 1, 1, 1, 0.8
                Line:
                    circle: self.center_x, self.center_y, dp(22), 90, 90 + root._arc_angle
                    width: dp(2.5)

            Label:
                text: str(int(root._remaining))
                pos: countdown_ring.pos
                size: countdown_ring.size
                font_name: 'Nunito'
                font_size: '14sp'
                bold: True
                color: 1, 1, 1, 0.9
                halign: 'center'
                valign: 'middle'
                text_size: self.size
