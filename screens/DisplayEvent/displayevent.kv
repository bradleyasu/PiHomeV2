#:kivy 2.0.0
#:import dp kivy.metrics.dp

<DisplayEvent>:

    # ── Solid background color ─────────────────────────────────────────────────
    canvas.before:
        Color:
            rgba: root.background
        Rectangle:
            pos: self.pos
            size: self.size

    # ── Floating card ──────────────────────────────────────────────────────────
    # Orientation switches based on image aspect ratio:
    #   portrait image  → horizontal (image LEFT, text RIGHT)
    #   landscape image → vertical   (image TOP,  text BOTTOM)
    #   no image        → vertical   (just the text pane)
    BoxLayout:
        id: card
        orientation: 'horizontal' if (root.image and not root._img_landscape) else 'vertical'
        size_hint: None, None
        width: (min(root.height * 0.5 * root._img_aspect, root.width - dp(48))) if (root.image and root._img_landscape) else root.width * 0.88
        height: root.height * 0.84
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}

        canvas.before:
            # ── Soft multi-layer drop shadow ──────────────────────────────────
            Color:
                rgba: 0, 0, 0, 0.22
            RoundedRectangle:
                pos: self.x + dp(2), self.y - dp(7)
                size: self.width + dp(2), self.height + dp(2)
                radius: [dp(20)]
            Color:
                rgba: 0, 0, 0, 0.10
            RoundedRectangle:
                pos: self.x + dp(5), self.y - dp(13)
                size: self.width + dp(4), self.height + dp(4)
                radius: [dp(20)]
            # ── Stencil clip — rounds all children including the image ─────────
            StencilPush
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
            StencilUse
            # ── White card surface ────────────────────────────────────────────
            Color:
                rgba: root.card_color
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
        canvas.after:
            StencilUnUse
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(20)]
            StencilPop

        # ── Image pane ─────────────────────────────────────────────────────────
        # Takes 42 % of the width (portrait) or 42 % of the height (landscape).
        # Collapses to zero when no image is set.
        AsyncImage:
            id: card_image
            source: root.image
            allow_stretch: True
            keep_ratio: True
            # size_hint along main axis / cross axis per orientation
            size_hint_x: 0.42 if (root.image and not root._img_landscape) else 1
            size_hint_y: None if root._img_landscape else (1 if (root.image and not root._img_landscape) else 0)
            height: (root.height * 0.5) if root._img_landscape else dp(0)
            opacity: 1 if root.image else 0
            on_texture: root._on_img_texture(self, self.texture)
            canvas.before:
                # Subtle image placeholder tone
                Color:
                    rgba: root.card_color[0] * 0.94, root.card_color[1] * 0.94, root.card_color[2] * 0.94, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

        # ── Content pane ───────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            padding: dp(24), dp(20), dp(24), dp(14)
            spacing: dp(10)
            size_hint_x: 0.58 if (root.image and not root._img_landscape) else 1
            size_hint_y: 1

            # ── Title ──────────────────────────────────────────────────────────
            Label:
                text: root.title
                font_name: 'Nunito'
                bold: True
                font_size: '20sp'
                color: root.text_color
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                halign: 'left'
                valign: 'top'

            # ── Divider ────────────────────────────────────────────────────────
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.3
                    Rectangle:
                        pos: self.pos
                        size: self.size

            # ── Scrollable message ─────────────────────────────────────────────
            ScrollView:
                id: scroll_area
                size_hint_y: 1
                do_scroll_x: False
                bar_color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.6
                bar_inactive_color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.2
                bar_width: dp(3)

                Label:
                    text: root.message
                    font_name: 'Nunito'
                    font_size: '14sp'
                    color: root.muted_color
                    size_hint_y: None
                    height: self.texture_size[1]
                    text_size: self.width, None
                    halign: 'left'
                    valign: 'top'

            # ── Footer: dismiss hint + countdown ring ──────────────────────────
            BoxLayout:
                orientation: 'horizontal'
                size_hint_y: None
                height: dp(40)
                spacing: dp(8)

                Label:
                    text: 'Tap anywhere to dismiss'
                    font_name: 'Nunito'
                    font_size: '11sp'
                    color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.6
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.size

                # Countdown ring — hidden when no timeout is set
                Widget:
                    id: countdown_ring
                    size_hint: None, None
                    size: dp(36), dp(36)
                    pos_hint: {'center_y': 0.5}
                    opacity: 1 if root.timeout_seconds > 0 else 0

                    canvas.before:
                        # Track
                        Color:
                            rgba: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.3
                        Line:
                            circle: self.center_x, self.center_y, dp(14), 0, 360
                            width: dp(2)
                        # Depleting filled arc
                        Color:
                            rgba: root.text_color
                        Line:
                            circle: self.center_x, self.center_y, dp(14), 90, 90 + root._arc_angle
                            width: dp(2)

                    Label:
                        text: str(int(root._remaining)) if root._remaining > 0 else ''
                        pos: countdown_ring.pos
                        size: countdown_ring.size
                        font_name: 'Nunito'
                        font_size: '11sp'
                        bold: True
                        color: root.text_color
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.size
