#:kivy 2.0.0
#:import dp kivy.metrics.dp

<DisplayEvent>:

    # ── Solid color background (fallback / tint when no image) ────────────────
    canvas.before:
        Color:
            rgba: root.background
        Rectangle:
            pos: self.pos
            size: self.size

    # ── Full-bleed background image ───────────────────────────────────────────
    AsyncImage:
        source: root.image
        allow_stretch: True
        keep_ratio: False
        size: root.size
        pos: root.pos
        opacity: 1 if root.image else 0

    # ── Dark scrim over the background image (softens contrast) ───────────────
    Widget:
        size: root.size
        pos: root.pos
        opacity: 0.45 if root.image else 0
        canvas:
            Color:
                rgba: 0, 0, 0, 1
            Rectangle:
                pos: self.pos
                size: self.size

    # ── Content layer ─────────────────────────────────────────────────────────
    FloatLayout:
        size: root.size
        pos: root.pos

        # Title + scrollable message, centred vertically with generous padding
        BoxLayout:
            orientation: 'vertical'
            spacing: dp(14)
            padding: dp(48), dp(48), dp(48), dp(72)
            size_hint: None, None
            width: root.width
            height: root.height
            pos: root.pos

            # ── Title ─────────────────────────────────────────────────────────
            Label:
                text: root.title
                font_name: 'Nunito'
                bold: True
                font_size: '28sp'
                color: 1, 1, 1, 1
                size_hint_y: None
                height: self.texture_size[1]
                text_size: self.width, None
                halign: 'center'
                valign: 'top'

            # ── Divider ───────────────────────────────────────────────────────
            Widget:
                size_hint_y: None
                height: dp(1)
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.15
                    Rectangle:
                        pos: self.x + dp(32), self.y
                        size: self.width - dp(64), dp(1)

            # ── Scrollable message ────────────────────────────────────────────
            ScrollView:
                id: scroll_area
                size_hint_y: 1
                do_scroll_x: False
                bar_color: 1, 1, 1, 0.25
                bar_inactive_color: 1, 1, 1, 0.08
                bar_width: dp(3)

                Label:
                    text: root.message
                    font_name: 'Nunito'
                    font_size: '16sp'
                    color: 1, 1, 1, 0.82
                    size_hint_y: None
                    height: max(self.texture_size[1], scroll_area.height)
                    text_size: self.width, None
                    halign: 'center'
                    valign: 'top'

        # ── "Tap to dismiss" hint at the bottom ───────────────────────────────
        Label:
            text: 'Tap anywhere to dismiss'
            font_name: 'Nunito'
            font_size: '11sp'
            color: 1, 1, 1, 0.28
            size_hint: None, None
            size: root.width, dp(28)
            pos: root.x, root.y + dp(14)
            halign: 'center'
            text_size: self.size

        # ── Countdown ring (bottom-right, hidden when no timeout) ─────────────
        Widget:
            id: countdown_ring
            opacity: 1 if root.timeout_seconds > 0 else 0
            size_hint: None, None
            size: dp(60), dp(60)
            pos: root.right - dp(76), root.y + dp(10)

            canvas.before:
                # Track ring
                Color:
                    rgba: 1, 1, 1, 0.12
                Line:
                    circle: self.center_x, self.center_y, dp(22), 0, 360
                    width: dp(2.5)
                # Depleting arc — starts full at top, shrinks counter-clockwise
                Color:
                    rgba: 1, 1, 1, 0.8
                Line:
                    circle: self.center_x, self.center_y, dp(22), 90, 90 + root._arc_angle
                    width: dp(2.5)

            Label:
                text: str(int(root._remaining))
                pos: countdown_ring.pos
                size: countdown_ring.size
                font_name: 'Nunito'
                font_size: '14sp'
                bold: True
                color: 1, 1, 1, 0.9
                halign: 'center'
                valign: 'middle'
                text_size: self.size
