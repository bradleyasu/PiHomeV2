#:kivy 2.0.0
#:import dp kivy.metrics.dp
#:import PiHomeSwitch components.Switch.switch.PiHomeSwitch
#:import PiTextInput components.Keyboard.keyboard.PiTextInput

# ─────────────────────────────────────────────────────────────────────────────
# PiTextInput global style — rounded, no default background chrome
# ─────────────────────────────────────────────────────────────────────────────
<PiTextInput>:
    background_normal: ''
    background_active: ''
    cursor_color: 0.36, 0.67, 1.0, 1
    foreground_color: 1, 1, 1, 1
    font_name: 'Nunito'
    font_size: '13sp'
    padding: [dp(10), dp(9)]
    multiline: False

# ─────────────────────────────────────────────────────────────────────────────
# Sidebar category pill
# ─────────────────────────────────────────────────────────────────────────────
<SettingsSidebarItem>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(42)
    padding: [dp(14), dp(4), dp(10), dp(4)]
    spacing: dp(8)

    canvas.before:
        # Highlight background for selected item
        Color:
            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.14 if root.is_selected else 0
        RoundedRectangle:
            pos:  self.pos[0] + dp(4), self.pos[1] + dp(2)
            size: self.width - dp(8), self.height - dp(4)
            radius: [dp(8)]
        # Left accent bar for selected item
        Color:
            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.9 if root.is_selected else 0
        RoundedRectangle:
            pos:  self.pos[0] + dp(4), self.pos[1] + dp(6)
            size: dp(3), self.height - dp(12)
            radius: [dp(2)]

    Label:
        text: root.label
        font_name: 'Nunito'
        font_size: '13sp'
        bold: root.is_selected
        color: (root.accent_color[0], root.accent_color[1], root.accent_color[2], 1) if root.is_selected else (root.text_color[0], root.text_color[1], root.text_color[2], 0.75)
        halign: 'left'
        valign: 'middle'
        text_size: self.size


# ─────────────────────────────────────────────────────────────────────────────
# Section title row
# ─────────────────────────────────────────────────────────────────────────────
<SettingsTitleRow>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(44)
    padding: [dp(6), dp(14), dp(6), dp(2)]

    Label:
        text: root.title.upper()
        font_name: 'Nunito'
        font_size: '10sp'
        bold: True
        color: root.line_color[0], root.line_color[1], root.line_color[2], 0.7
        halign: 'left'
        valign: 'bottom'
        text_size: self.size


# ─────────────────────────────────────────────────────────────────────────────
# String input row
# ─────────────────────────────────────────────────────────────────────────────
<SettingsStringRow>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(68)
    padding: [dp(16), dp(8), dp(16), dp(8)]
    spacing: dp(12)

    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos:  self.pos[0] + dp(4), self.pos[1] + dp(2)
            size: self.width - dp(8), self.height - dp(4)
            radius: [dp(10)]

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 1
        spacing: dp(2)
        Label:
            text: root.title
            font_name: 'Nunito'
            font_size: '14sp'
            bold: True
            color: root.text_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Label:
            text: root.desc
            font_name: 'Nunito'
            font_size: '11sp'
            color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.8
            halign: 'left'
            valign: 'middle'
            text_size: self.size

    PiTextInput:
        text: root.value
        size_hint: None, None
        size: dp(210), dp(38)
        pos_hint: {'center_y': 0.5}
        font_name: 'Nunito'
        font_size: '13sp'
        foreground_color: root.text_color
        background_color: root.muted_color[0]*0.15, root.muted_color[1]*0.15, root.muted_color[2]*0.15, 1
        cursor_color: root.accent_color
        on_text: root.value = self.text


# ─────────────────────────────────────────────────────────────────────────────
# Numeric input row
# ─────────────────────────────────────────────────────────────────────────────
<SettingsNumericRow>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(68)
    padding: [dp(16), dp(8), dp(16), dp(8)]
    spacing: dp(12)

    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos:  self.pos[0] + dp(4), self.pos[1] + dp(2)
            size: self.width - dp(8), self.height - dp(4)
            radius: [dp(10)]

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 1
        spacing: dp(2)
        Label:
            text: root.title
            font_name: 'Nunito'
            font_size: '14sp'
            bold: True
            color: root.text_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Label:
            text: root.desc
            font_name: 'Nunito'
            font_size: '11sp'
            color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.8
            halign: 'left'
            valign: 'middle'
            text_size: self.size

    PiTextInput:
        text: root.value
        size_hint: None, None
        size: dp(110), dp(38)
        pos_hint: {'center_y': 0.5}
        font_name: 'Nunito'
        font_size: '13sp'
        foreground_color: root.text_color
        background_color: root.muted_color[0]*0.15, root.muted_color[1]*0.15, root.muted_color[2]*0.15, 1
        cursor_color: root.accent_color
        input_filter: 'float'
        on_text: root.value = self.text


# ─────────────────────────────────────────────────────────────────────────────
# Bool toggle row — tap anywhere on the row to toggle
# ─────────────────────────────────────────────────────────────────────────────
<SettingsBoolRow>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(68)
    padding: [dp(16), dp(8), dp(16), dp(8)]
    spacing: dp(12)

    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos:  self.pos[0] + dp(4), self.pos[1] + dp(2)
            size: self.width - dp(8), self.height - dp(4)
            radius: [dp(10)]

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 1
        spacing: dp(2)
        Label:
            text: root.title
            font_name: 'Nunito'
            font_size: '14sp'
            bold: True
            color: root.text_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Label:
            text: root.desc
            font_name: 'Nunito'
            font_size: '11sp'
            color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.8
            halign: 'left'
            valign: 'middle'
            text_size: self.size

    PiHomeSwitch:
        size_hint: None, None
        size: dp(52), dp(30)
        pos_hint: {'center_y': 0.5}
        enabled: root.value
        on_enabled: root.value = self.enabled


# ─────────────────────────────────────────────────────────────────────────────
# Options popup row — tap the pill to open a dropdown
# ─────────────────────────────────────────────────────────────────────────────
<SettingsOptionsRow>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(68)
    padding: [dp(16), dp(8), dp(16), dp(8)]
    spacing: dp(12)

    canvas.before:
        Color:
            rgba: root.bg_color
        RoundedRectangle:
            pos:  self.pos[0] + dp(4), self.pos[1] + dp(2)
            size: self.width - dp(8), self.height - dp(4)
            radius: [dp(10)]

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 1
        spacing: dp(2)
        Label:
            text: root.title
            font_name: 'Nunito'
            font_size: '14sp'
            bold: True
            color: root.text_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Label:
            text: root.desc
            font_name: 'Nunito'
            font_size: '11sp'
            color: root.muted_color[0], root.muted_color[1], root.muted_color[2], 0.8
            halign: 'left'
            valign: 'middle'
            text_size: self.size

    # Pill button — shows current value, opens dropdown on tap
    BoxLayout:
        size_hint: None, None
        size: dp(180), dp(38)
        pos_hint: {'center_y': 0.5}
        padding: [dp(14), 0, dp(10), 0]
        spacing: 0
        on_touch_down: self.collide_point(*args[1].pos) and root.open_dropdown()

        canvas.before:
            # Border ring
            Color:
                rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.38
            RoundedRectangle:
                pos:  self.pos[0] - dp(1), self.pos[1] - dp(1)
                size: self.width + dp(2), self.height + dp(2)
                radius: [dp(10)]
            # Fill
            Color:
                rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.11
            RoundedRectangle:
                pos:  self.pos
                size: self.size
                radius: [dp(9)]

        Label:
            text: root.value
            font_name: 'Nunito'
            font_size: '13sp'
            bold: True
            color: root.accent_color
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            size_hint_x: 1

        Label:
            text: '\u2304'
            font_name: 'ArialUnicode'
            font_size: '16sp'
            color: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.65
            size_hint: None, 1
            width: dp(18)
            halign: 'center'
            valign: 'middle'
            text_size: self.size

# ─────────────────────────────────────────────────────────────────────────────
# Root screen
# ─────────────────────────────────────────────────────────────────────────────
<SettingsScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos:  self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        size_hint: 1, 1

        # ── Header ────────────────────────────────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: dp(52)
            padding: [dp(68), dp(8), dp(14), dp(8)]
            spacing: dp(10)

            canvas.before:
                Color:
                    rgba: root.header_color
                Rectangle:
                    pos:  self.pos
                    size: self.size

            # Back / done button
            BoxLayout:
                size_hint: None, None
                size: dp(36), dp(36)
                pos_hint: {'center_y': 0.5}
                canvas.before:
                    Color:
                        rgba: 1, 1, 1, 0.07
                    RoundedRectangle:
                        pos:  self.pos
                        size: self.size
                        radius: [dp(9)]
                on_touch_down:
                    if self.collide_point(*args[1].pos): root._save_and_close()
                Label:
                    text: '\u2039'
                    font_name: 'ArialUnicode'
                    font_size: '26sp'
                    color: root.text_color
                    halign: 'center'
                    valign: 'middle'
                    pos_hint: {'center_y': 0.6}
                    text_size: self.parent.size if self.parent else self.size

            Label:
                text: 'Settings'
                font_name: 'Nunito'
                font_size: '18sp'
                bold: True
                color: root.text_color
                halign: 'left'
                valign: 'middle'
                text_size: self.size
                size_hint_x: 1

        # ── Body: sidebar + content ───────────────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint: 1, 1

            # Left sidebar
            BoxLayout:
                id: settings_sidebar
                orientation: 'vertical'
                size_hint_x: None
                width: dp(175)
                padding: [dp(6), dp(10), dp(6), dp(10)]
                spacing: dp(2)

                canvas.before:
                    Color:
                        rgba: root.sidebar_color
                    Rectangle:
                        pos:  self.pos
                        size: self.size

            # Thin divider
            Widget:
                size_hint_x: None
                width: dp(1)
                canvas:
                    Color:
                        rgba: root.divider_color
                    Rectangle:
                        pos:  self.pos
                        size: self.size

            # Scrollable right panel
            ScrollView:
                id: settings_scroll
                size_hint: 1, 1
                do_scroll_x: False
                bar_width: dp(3)
                bar_color: root.accent_color
                bar_inactive_color: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.2
                scroll_type: ['bars', 'content']

                BoxLayout:
                    id: settings_content
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [dp(10), dp(10), dp(10), dp(10)]
                    spacing: dp(4)

