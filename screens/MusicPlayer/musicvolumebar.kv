#:kivy 2.0.0
#:import dp kivy.metrics.dp

# ─────────────────────────────────────────────────────────────────────────────
# MusicVolumeBar — thin, scrubber-style horizontal volume control
#
#  ──────────────────●────────────────
#  dim track  accent fill  handle dot
#
# All drawing is pure canvas so there are no sub-widgets to interfere with
# touch propagation.  The Python class handles all hit-testing.
# ─────────────────────────────────────────────────────────────────────────────
<MusicVolumeBar>:
    size_hint_y: None
    height: dp(28)

    canvas:
        # ── dim full-width track ────────────────────────────────────────────
        Color:
            rgba: root.track_color
        RoundedRectangle:
            pos:  self.x,               self.center_y - dp(2)
            size: self.width,           dp(4)
            radius: [dp(2)]

        # ── accent-colored fill up to current value ─────────────────────────
        Color:
            rgba: root.accent_color
        RoundedRectangle:
            pos:  self.x,               self.center_y - dp(2)
            size: root.fill_w,          dp(4)
            radius: [dp(2)]

        # ── handle: solid bright circle ─────────────────────────────────────
        Color:
            rgba: 1, 1, 1, 1
        Ellipse:
            pos:  self.x + root.fill_w - dp(7),  self.center_y - dp(7)
            size: dp(14),               dp(14)

        # ── handle inner accent ring (gives depth) ──────────────────────────
        Color:
            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.6
        Line:
            circle: self.x + root.fill_w, self.center_y, dp(5)
            width: dp(1.5)
