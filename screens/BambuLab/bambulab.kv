#:kivy 2.0.0
#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

<BambuLabScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            size: self.size
            pos: self.pos
        # Subtle accent glow — top-left corner
        Color:
            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], 0.05
        Ellipse:
            pos: -dp(60), self.height * 0.4
            size: self.width * 0.55, self.height * 0.9

    BoxLayout:
        orientation: "vertical"
        size_hint: 1, 1

        # ── Header ────────────────────────────────────────────────────────────
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: dp(44)
            padding: dp(54), 0, dp(10), 0
            spacing: dp(8)
            canvas.before:
                Color:
                    rgba: root.header_color
                Rectangle:
                    size: self.size
                    pos: self.pos
                # Bottom border
                Color:
                    rgba: 1, 1, 1, 0.06
                Rectangle:
                    size: self.width, dp(1)
                    pos: self.x, self.y

            # Printer icon (MaterialIcons "print")
            Label:
                text: "\ue8ad"
                font_name: "MaterialIcons"
                font_size: sp(20)
                color: root.accent_color
                size_hint_x: None
                width: dp(26)
                halign: "center"
                valign: "middle"

            # Screen title
            Label:
                text: "BAMBU LAB"
                font_name: "Nunito"
                font_size: sp(12)
                bold: True
                color: root.text_color
                size_hint_x: None
                width: dp(90)
                halign: "left"
                valign: "middle"
                text_size: self.size

            Widget:

            # Connection status dot
            Widget:
                size_hint: None, None
                size: dp(8), dp(8)
                pos_hint: {"center_y": 0.5}
                canvas:
                    Color:
                        rgba: root.status_color
                    Ellipse:
                        pos: self.pos
                        size: self.size

            # Connection state label — uses pre-formatted Python property
            Label:
                text: root.connection_label
                font_name: "Nunito"
                font_size: sp(10)
                color: root.status_color
                size_hint_x: None
                width: dp(86)
                halign: "left"
                valign: "middle"
                text_size: self.size

            # State badge (PRINTING / IDLE / PAUSED / etc.)
            Label:
                text: root.state_label
                font_name: "Nunito"
                font_size: sp(9)
                bold: True
                color: root.bg_color
                size_hint: None, None
                size: dp(72), dp(24)
                pos_hint: {"center_y": 0.5}
                halign: "center"
                valign: "middle"
                canvas.before:
                    Color:
                        rgba: root.state_color
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(4)]

        # ── Body ──────────────────────────────────────────────────────────────
        BoxLayout:
            orientation: "horizontal"

            # ── Camera panel ──────────────────────────────────────────────────
            FloatLayout:
                id: camera_panel
                size_hint_x: 0.575
                canvas.before:
                    Color:
                        rgba: 0.025, 0.025, 0.04, 1
                    Rectangle:
                        size: self.size
                        pos: self.pos

                # Texture display — fills full panel, 16:9 letterboxed
                Widget:
                    size_hint: 1, 1
                    canvas:
                        Color:
                            rgba: 1, 1, 1, (1 if root.camera_texture else 0)
                        Rectangle:
                            texture: root.camera_texture
                            size: self.width, self.width * 9.0 / 16.0
                            pos: self.x, self.y + (self.height - self.width * 9.0 / 16.0) / 2.0

                # No-camera placeholder
                BoxLayout:
                    orientation: "vertical"
                    spacing: dp(6)
                    size_hint: None, None
                    size: dp(200), dp(76)
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    opacity: 0 if root.camera_texture else 1

                    Label:
                        text: "\ue04b"
                        font_name: "MaterialIcons"
                        font_size: sp(34)
                        color: 1, 1, 1, 0.15
                        halign: "center"

                    # Uses pre-formatted Python property — no string literals in binding
                    Label:
                        text: root.camera_label
                        font_name: "Nunito"
                        font_size: sp(12)
                        color: 1, 1, 1, 0.28
                        halign: "center"
                        text_size: self.width, None

            # ── Vertical divider ──────────────────────────────────────────────
            Widget:
                size_hint_x: None
                width: dp(1)
                canvas:
                    Color:
                        rgba: 1, 1, 1, 0.07
                    Rectangle:
                        size: self.size
                        pos: self.pos

            # ── Status panel ──────────────────────────────────────────────────
            BoxLayout:
                id: status_panel
                orientation: "vertical"
                size_hint_x: 0.425
                padding: dp(14), dp(10), dp(10), dp(8)
                spacing: 0

                # ── Job section ───────────────────────────────────────────────
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(162)
                    padding: dp(6), dp(6)
                    spacing: dp(4)
                    canvas.before:
                        Color:
                            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], (0.10 if root.stat_page == 0 else 0)
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(5)]

                    Label:
                        text: "PRINT JOB"
                        font_name: "Nunito"
                        font_size: sp(9)
                        color: root.muted_color
                        size_hint_y: None
                        height: dp(16)
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    Label:
                        text: root.job_name
                        font_name: "Nunito"
                        font_size: sp(13)
                        bold: True
                        color: root.text_color
                        size_hint_y: None
                        height: dp(22)
                        halign: "left"
                        valign: "middle"
                        text_size: self.width, None
                        shorten: True
                        shorten_from: "right"

                    # Progress bar
                    Widget:
                        size_hint_y: None
                        height: dp(10)
                        canvas:
                            # Track
                            Color:
                                rgba: 1, 1, 1, 0.09
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(5)]
                            # Fill
                            Color:
                                rgba: root.accent_color
                            RoundedRectangle:
                                pos: self.pos
                                size: max(dp(10), self.width * root.print_progress / 100.0), self.height
                                radius: [dp(5)]

                    # Progress % and layer — uses pre-formatted Python properties
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(22)
                        Label:
                            text: root.progress_text
                            font_name: "Nunito"
                            font_size: sp(14)
                            bold: True
                            color: root.accent_color
                            halign: "left"
                            valign: "middle"
                            text_size: self.size

                        Label:
                            text: root.layer_text
                            font_name: "Nunito"
                            font_size: sp(11)
                            color: root.muted_color
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                    # ETA — pre-formatted Python property
                    Label:
                        text: root.eta_text
                        font_name: "Nunito"
                        font_size: sp(12)
                        color: root.text_color
                        size_hint_y: None
                        height: dp(20)
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    Widget:

                # Divider
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: 1, 1, 1, 0.07
                        Rectangle:
                            size: self.size
                            pos: self.pos

                # ── Temperature section ───────────────────────────────────────
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(118)
                    padding: dp(6), dp(6)
                    spacing: dp(2)
                    canvas.before:
                        Color:
                            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], (0.10 if root.stat_page == 1 else 0)
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(5)]

                    Label:
                        text: "TEMPERATURES"
                        font_name: "Nunito"
                        font_size: sp(9)
                        color: root.muted_color
                        size_hint_y: None
                        height: dp(16)
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    # Nozzle — pre-formatted Python property
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(28)
                        Label:
                            text: "Nozzle"
                            font_name: "Nunito"
                            font_size: sp(12)
                            color: root.muted_color
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: root.nozzle_text
                            font_name: "Nunito"
                            font_size: sp(14)
                            bold: True
                            color: ([1, 0.42, 0.22, 1] if root.temp_nozzle > 100 else root.text_color)
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                    # Bed
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(28)
                        Label:
                            text: "Bed"
                            font_name: "Nunito"
                            font_size: sp(12)
                            color: root.muted_color
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: root.bed_text
                            font_name: "Nunito"
                            font_size: sp(14)
                            bold: True
                            color: ([1, 0.60, 0.22, 1] if root.temp_bed > 40 else root.text_color)
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                    # Chamber
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(28)
                        Label:
                            text: "Chamber"
                            font_name: "Nunito"
                            font_size: sp(12)
                            color: root.muted_color
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: root.chamber_text
                            font_name: "Nunito"
                            font_size: sp(14)
                            bold: True
                            color: root.text_color
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                # Divider
                Widget:
                    size_hint_y: None
                    height: dp(1)
                    canvas:
                        Color:
                            rgba: 1, 1, 1, 0.07
                        Rectangle:
                            size: self.size
                            pos: self.pos

                # ── Speed & filament section ──────────────────────────────────
                BoxLayout:
                    orientation: "vertical"
                    padding: dp(6), dp(6)
                    spacing: dp(2)
                    canvas.before:
                        Color:
                            rgba: root.accent_color[0], root.accent_color[1], root.accent_color[2], (0.10 if root.stat_page == 2 else 0)
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(5)]

                    Label:
                        text: "SPEED & MATERIAL"
                        font_name: "Nunito"
                        font_size: sp(9)
                        color: root.muted_color
                        size_hint_y: None
                        height: dp(16)
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    # Speed — pre-formatted Python property
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(28)
                        Label:
                            text: "Speed"
                            font_name: "Nunito"
                            font_size: sp(12)
                            color: root.muted_color
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: root.speed_text
                            font_name: "Nunito"
                            font_size: sp(14)
                            bold: True
                            color: root.text_color
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                    # Filament
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(28)
                        Label:
                            text: "Filament"
                            font_name: "Nunito"
                            font_size: sp(12)
                            color: root.muted_color
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: root.filament_type
                            font_name: "Nunito"
                            font_size: sp(13)
                            bold: True
                            color: root.text_color
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                    Widget:

                    # Page indicator dots
                    BoxLayout:
                        orientation: "horizontal"
                        size_hint_y: None
                        height: dp(14)
                        spacing: dp(6)
                        padding: 0, dp(2)

                        Widget:

                        Widget:
                            size_hint: None, None
                            size: dp(7), dp(7)
                            pos_hint: {"center_y": 0.5}
                            canvas:
                                Color:
                                    rgba: (root.accent_color if root.stat_page == 0 else [1, 1, 1, 0.22])
                                Ellipse:
                                    pos: self.pos
                                    size: self.size

                        Widget:
                            size_hint: None, None
                            size: dp(7), dp(7)
                            pos_hint: {"center_y": 0.5}
                            canvas:
                                Color:
                                    rgba: (root.accent_color if root.stat_page == 1 else [1, 1, 1, 0.22])
                                Ellipse:
                                    pos: self.pos
                                    size: self.size

                        Widget:
                            size_hint: None, None
                            size: dp(7), dp(7)
                            pos_hint: {"center_y": 0.5}
                            canvas:
                                Color:
                                    rgba: (root.accent_color if root.stat_page == 2 else [1, 1, 1, 0.22])
                                Ellipse:
                                    pos: self.pos
                                    size: self.size

                        Widget:
